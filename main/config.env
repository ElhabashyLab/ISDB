### Parameters
# Please adjust "tempory_directory" to the path in which the database can be built
OUT_DIRECTORY=/etc/ISDB
# Overwrite existing out files: false, true
OVERWRITE=false
# Addtional data (optional): e.g. filepath: <myFile.csv> or directory: <myFiles/> 
ADDITIONAL_DATA=
# Delete tempory files
DELETE=false

### Manual files
# "false" -> no manual downloaded databases
# "true" -> includes manual downloaded databases (file path need to be specified below)
MANUAL_DATABASES=false
# Files
BATECO_FILE=BatEco-InteractionRecords.csv
PHISTO_FILE=phisto_data.csv
PHILM2WEB_FILE=philm2web.csv
FGSCDB_FILE=FGSCdb_data.csv
# Directories
BVBRC_DIR=bvbrc
DIP_DIR=dip
GMPD_DIR=gmpd

### Automatic downloaded databases
# Files 
GLOBI_FILE=globi.tsv
INTACT_FILE=intact.txt
PHI_BASE_FILE=phi_base.csv
PIDA_FILE=pida.tsv
VIRHOSTNET_FILE=vir_host_net.tsv
EID2=EID2.csv
SIAD=siad.txt
MINT_FILE=mint.tsv
SIGNOR_FILE=signor.tsv
# Directories
BIOGRID_DIR=biogrid_all_latest
WEB_OF_LIFE_DATABASE_DIR=web_of_life
HPIDB_DIR=hpidb
IWDB_DIR=iwdb
PMC9897028_DIR=viral_interactome
